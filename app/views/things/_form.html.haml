= form_with(model: thing) do |form|
  - if thing.errors.any?
    %div{style: "color: red"}
      %h2= "#{pluralize(thing.errors.count, "error")} prohibited this thing from being saved:"

      %ul
        - thing.errors.each do |error|
          %li= error.full_message

  %div
    = form.label :name, style: "display: block"
    = form.text_field :name

  %div
    = form.label :color, style: "display: block"
    = form.text_field :color

  %div
    = form.label :grade, style: "display: block"
    = form.number_field :grade

  %div
    = form.submit
